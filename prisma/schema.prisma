generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Meal {
  id                   String   @id @default(cuid())
  clerkUserId          String
  imageUrl             String
  foodName             String
  estimatedWeightGrams Float
  calories             Float
  protein              Float
  carbs                Float
  fat                  Float
  fiber                Float
  confidence           Float
  vitamins             Json
  aiRawResponse        Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([clerkUserId, createdAt])
}

model UserPreference {
  id                  String   @id @default(cuid())
  clerkUserId         String   @unique
  dailyCaloriesTarget Float    @default(2000)
  dailyProteinTarget  Float    @default(100)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
